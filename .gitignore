# Private/generated Elementor outputs
elementor-outputs/elementor-templates/*.json
elementor-outputs/private-templates/**

# Keep public placeholder files inside ignored output folders
!elementor-outputs/elementor-templates/.gitkeep
!elementor-outputs/elementor-templates/README.md
!elementor-outputs/private-templates/.gitkeep
!elementor-outputs/private-templates/README.md

# Public reference exports are allowed
!elementor-outputs/
!elementor-outputs/README.md
!elementor-outputs/references/
!elementor-outputs/references/**
!elementor-outputs/section-maps/
!elementor-outputs/section-maps/**

# Private local agent/daily work notes
AGENTS.local.md
AGENT_PRIVATE_NOTES.md
LOCAL_DAILY_WORK.md
DAILY_WORKLOG.md

# Client media/assets should not be committed by default
*.jpg
*.jpeg
*.png
*.webp
*.gif
*.svg
*.pdf
*.psd
*.ai
*.indd

# Allow documentation images only when placed in approved public reference folders
!elementor-outputs/references/screenshots/
!elementor-outputs/references/screenshots/**